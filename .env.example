# ─── Database ───────────────────────────────────────────────────────────────────
# For docker compose: use the service name "postgres"
# For local dev: use localhost
DATABASE_URL=postgresql://risex:CHANGE_ME_DB_PASSWORD@postgres:5432/risex_db

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Telegram Bot ───────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# ─── Risechain RPC ──────────────────────────────────────────────────────────────
# Risechain testnet (Chain ID: 11155931)
# Public endpoint: https://testnet.risechain.com
RISECHAIN_RPC_URL=https://testnet.risechain.com
RISECHAIN_WS_URL=wss://testnet.risechain.com
RISECHAIN_CHAIN_ID=11155931
# USDC contract address on Risechain testnet — check https://docs.risechain.com
USDC_CONTRACT_ADDRESS=0x

# ─── RISEx API ──────────────────────────────────────────────────────────────────
# Get credentials from https://developer.rise.trade
RISEX_API_BASE=https://api.rise.trade
RISEX_WS_URL=wss://ws.rise.trade
RISEX_API_KEY=
RISEX_API_SECRET=

# ─── RISEx EIP-712 Trading Keys ─────────────────────────────────────────────────
# Main wallet private key (hex, with or without 0x) — holds funds on Risechain
ACCOUNT_PRIVATE_KEY=
# Session/signer private key for signing orders (can be a separate hot wallet)
SIGNER_PRIVATE_KEY=

# ─── Security ───────────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting wallet private keys — MUST be 64 hex chars (32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Web Dashboard ──────────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_RISECHAIN_RPC=https://testnet.risechain.com
# Get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_BOT_URL=https://t.me/RiseChain_RISEx_Bot

# ─── API Server ─────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
ALLOWED_ORIGINS=http://localhost:3000

# ─── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production

# ─── Trading Engine ─────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=10
